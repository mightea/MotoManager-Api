meta {
  name: Create Previous Owner
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/motorcycles/{{motorcycleId}}/previous-owners
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

