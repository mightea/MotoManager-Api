  {
    "name": "John",
    "surname": "Doe",
    "purchaseDate": "2022-06-15",
    "email": "john.doe@example.com",
    "phoneNumber": "+1234567890",
    "address": "123 Main St",
    "city": "Springfield",
    "postcode": "12345",
    "country": "US",
    "comments": ""
  }
}
