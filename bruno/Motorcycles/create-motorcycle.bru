meta {
  name: Create Motorcycle
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/motorcycles
  body: multipart-form
  auth: none
}

headers {
  Authorization: Bearer {{token}}
}

body:multipart-form {
  make: Honda
  model: CB500F
  fabricationDate: 2020-01-01
  vin:
  engineNumber:
  vehicleNr:
  numberPlate:
  isVeteran: false
  initialOdo: 0
  purchaseDate:
  purchasePrice:
  currencyCode: EUR
  fuelTankSize:
  firstRegistration:
  image:
}
