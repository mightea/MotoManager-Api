meta {
  name: Login
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "identifier": "admin",
    "password": "password"
  }
}

script:post-response {
  const data = res.getBody();
  if (data.token) {
    bru.setEnvVar("sessionToken", data.token);
  }
}
