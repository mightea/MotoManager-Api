meta {
  name: Register
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "name": "Admin User",
    "email": "admin@example.com",
    "username": "admin",
    "password": "password",
    "confirmPassword": "password"
  }
}

script:post-response {
  const data = res.getBody();
  if (data.token) {
    bru.setEnvVar("token", data.token);
  }
}
